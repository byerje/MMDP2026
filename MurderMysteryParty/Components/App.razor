@using Microsoft.AspNetCore.Components.WebAssembly.Services
@using MurderMysteryParty.Services
@using Microsoft.JSInterop
@implements IAsyncDisposable
@inject RoundSignalRService RoundSignalRService
@inject GameSessionService GameSessionService
@inject CharacterService CharacterService
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime

<Routes />

@code {
    private DotNetObjectReference<App>? _selfRef;

    protected override async Task OnInitializedAsync()
    {
        RoundSignalRService.RoundUnlocked += OnRoundUnlocked;
        RoundSignalRService.CharacterAssignmentChanged += OnCharacterAssignmentChanged;
        await RoundSignalRService.StartAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _selfRef = DotNetObjectReference.Create(this);
            await JSRuntime.InvokeVoidAsync("registerBlazorNavigator", _selfRef);
        }
    }

    [JSInvokable]
    public void NavigateToUrl(string url)
    {
        // Convert absolute URL to a relative path that Blazor can route internally
        if (Uri.TryCreate(url, UriKind.Absolute, out var uri))
        {
            var basePath = new Uri(NavigationManager.BaseUri).AbsolutePath.TrimEnd('/');
            var relative = uri.PathAndQuery;
            if (relative.StartsWith(basePath, StringComparison.OrdinalIgnoreCase))
            {
                relative = relative.Substring(basePath.Length);
            }
            if (string.IsNullOrEmpty(relative))
            {
                relative = "/";
            }
            NavigationManager.NavigateTo(relative, forceLoad: false);
        }
        else
        {
            NavigationManager.NavigateTo(url, forceLoad: false);
        }
    }

    private Task OnRoundUnlocked(int round)
    {
        GameSessionService.ApplyRoundUnlock(round);
        return Task.CompletedTask;
    }

    private Task OnCharacterAssignmentChanged(int characterId, bool isAssigned)
    {
        CharacterService.ApplyAssignmentChange(characterId, isAssigned);
        return Task.CompletedTask;
    }

    public async ValueTask DisposeAsync()
    {
        RoundSignalRService.RoundUnlocked -= OnRoundUnlocked;
        RoundSignalRService.CharacterAssignmentChanged -= OnCharacterAssignmentChanged;
        await RoundSignalRService.DisposeAsync();
        _selfRef?.Dispose();
    }
}

