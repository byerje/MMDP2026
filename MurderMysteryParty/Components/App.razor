@using Microsoft.AspNetCore.Components.WebAssembly.Services
@using MurderMysteryParty.Services
@implements IAsyncDisposable
@inject RoundSignalRService RoundSignalRService
@inject GameSessionService GameSessionService
@inject CharacterService CharacterService
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime

<Routes />

@code {
    protected override async Task OnInitializedAsync()
    {
        RoundSignalRService.RoundUnlocked += OnRoundUnlocked;
        RoundSignalRService.CharacterAssignmentChanged += OnCharacterAssignmentChanged;
        await RoundSignalRService.StartAsync();
    }

    protected override void OnAfterRender(bool firstRender)
    {
        if (firstRender)
        {
            // Removed refresh redirect logic - GitHub Pages 404.html now handles page refresh
            // Pages should stay on current page when refreshed
        }
    }

    private Task OnRoundUnlocked(int round)
    {
        GameSessionService.ApplyRoundUnlock(round);
        return Task.CompletedTask;
    }

    private Task OnCharacterAssignmentChanged(int characterId, bool isAssigned)
    {
        CharacterService.ApplyAssignmentChange(characterId, isAssigned);
        return Task.CompletedTask;
    }

    public async ValueTask DisposeAsync()
    {
        RoundSignalRService.RoundUnlocked -= OnRoundUnlocked;
        RoundSignalRService.CharacterAssignmentChanged -= OnCharacterAssignmentChanged;
        await RoundSignalRService.DisposeAsync();
    }
}

