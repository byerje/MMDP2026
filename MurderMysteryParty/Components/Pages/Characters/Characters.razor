@page "/characters"
@using MurderMysteryParty.Models
@using MurderMysteryParty.Services
@inject CharacterService CharacterService
@inject GameSessionService GameSessionService
@inject RoundSignalRService RoundSignalRService
@implements IDisposable

<PageTitle>Characters - Murder Mystery Dinner Party</PageTitle>

<div class="character-list-container">
    <div class="header">
        <h1 class="page-title">Meet the Cast</h1>
        <h2 class="page-subtitle">1920's SpeakEasy Gala Character Profiles</h2>
        @if (isSyncing)
        {
            <p class="refresh-message syncing-message">⏳ Syncing with host...</p>
        }
        else if (showRefreshMessage)
        {
            <p class="refresh-message">✓ Character list updated!</p>
        }
        <div class="navigation-buttons">
            <a href="" class="back-home-btn">🏠 Back to Home</a>
            <a href="floorplan" class="floor-plan-btn">🗺️ Floor Plan</a>
            <a href="my-character" class="character-btn">🎭 My Character</a>
            <a href="notebook" class="notebook-btn">🗒️ Notebook</a>
            @if (GameSessionService.GetGameSession().IsRound2BUnlocked)
            {
                <a href="forensic-report" class="forensic-btn">🔬 Forensic Report</a>
            }
            else
            {
                <button class="forensic-btn-locked" disabled title="Available after Round 2B is unlocked">🔒 Forensic Report</button>
            }
            <button class="refresh-btn" @onclick="RefreshCharacterList">🔄 Refresh</button>
        </div>
    </div>

    <div class="characters-grid">
        @foreach (var character in allCharacters)
        {
            @if (GameSessionService.GetGameSession().IsDirectAssignmentAllowed)
            {
                <a href="character/@character.Id" class="character-profile-link">
                    <div class="character-profile @(character.IsAssigned ? "assigned" : "")">
                        <div class="character-header">
                            <h3 class="character-name">@character.Name</h3>
                            @if (character.IsAssigned)
                            {
                                <span class="assigned-badge">ASSIGNED</span>
                            }
                        </div>
                        <div class="character-details">
                            <div class="basic-info">
                                <p><strong>Occupation:</strong> @character.Occupation</p>
                                <p><strong>Description:</strong> @character.Description</p>
                            </div>
                        </div>
                    </div>
                </a>
            }
            else
            {
                <div class="character-profile @(character.IsAssigned ? "assigned" : "") qr-only">
                    <div class="character-header">
                        <h3 class="character-name">@character.Name</h3>
                        @if (character.IsAssigned)
                        {
                            <span class="assigned-badge">ASSIGNED</span>
                        }
                        else
                        {
                            <span class="qr-only-badge">📷</span>
                        }
                    </div>
                    <div class="character-details">
                        <div class="basic-info">
                            <p><strong>Occupation:</strong> @character.Occupation</p>
                            <p><strong>Description:</strong> @character.Description</p>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>

@code {
    private List<Character> allCharacters = new();
    private bool showRefreshMessage;
    private bool isSyncing;
    private Timer? refreshMessageTimer;

    protected override void OnInitialized()
    {
        allCharacters = CharacterService.GetAllCharacters();
        CharacterService.OnAssignmentsChanged += OnAssignmentsChanged;
        GameSessionService.OnGameStateChanged += OnGameStateChanged;
    }

    private async void OnGameStateChanged()
    {
        await InvokeAsync(StateHasChanged);
    }

    private async void OnAssignmentsChanged()
    {
        allCharacters = CharacterService.GetAllCharacters();
        await InvokeAsync(StateHasChanged);
    }

    private void ResetAssignments()
    {
        CharacterService.ResetCharacterAssignments();
        allCharacters = CharacterService.GetAllCharacters();
    }

    private async Task RefreshCharacterList()
    {
        isSyncing = true;
        showRefreshMessage = false;
        StateHasChanged();

        // Request the admin to broadcast current assignments via SignalR
        await RoundSignalRService.SendAssignmentSyncRequestAsync();

        // Wait for the SignalR round-trip: request → admin → broadcast → this client
        await Task.Delay(2000);

        allCharacters = CharacterService.GetAllCharacters();
        isSyncing = false;
        showRefreshMessage = true;
        StateHasChanged();

        refreshMessageTimer?.Dispose();
        refreshMessageTimer = new Timer(_ => 
        {
            showRefreshMessage = false;
            InvokeAsync(StateHasChanged);
        }, null, TimeSpan.FromSeconds(2), Timeout.InfiniteTimeSpan);
    }

    public void Dispose()
    {
        CharacterService.OnAssignmentsChanged -= OnAssignmentsChanged;
        GameSessionService.OnGameStateChanged -= OnGameStateChanged;
        refreshMessageTimer?.Dispose();
    }
}

