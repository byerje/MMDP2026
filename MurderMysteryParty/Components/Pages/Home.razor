@page "/"
@using MurderMysteryParty.Services
@inject AdminAuthService AdminAuthService

<PageTitle>Murder Mystery Dinner Party - 1920's SpeakEasy Gala 2026</PageTitle>

<div class="speakeasy-container">
    <div class="invitation-header">
        <h1 class="gatsby-title">Murder Mystery Dinner Party</h1>
        <h2 class="event-subtitle">1920's SpeakEasy Gala 2026</h2>
        <h3 class="date-location">Mar 13, 2026 | Silver Serpent Speakeasy</h3>
    </div>

    <div class="invitation-content">
        <div class="art-deco-border">
            <p class="invitation-text">
                <em>Welcome to the past. Step back in time to the golden age of jazz, glitz, and glamour!</em>
            </p>
            
            <p class="invitation-details">
                Thank you for joining us for an evening of mystery, intrigue, and 1920s sophistication as we gather at Silver 
                Serpent Speakeasy for an unforgettable murder mystery dinner party. Don your finest flapper dress or sharpest suit, 
                and prepare to become part of a thrilling whodunit that will test your detective skills!
            </p>

            <div class="party-details">
                <h4>What Awaits You:</h4>
                <ul>
                    <li>🍸 Prohibition-era mocktails</li>
                    <li>🎭 Interactive murder mystery experience</li>
                    <li>🎷 Great music and 1920s entertainment</li>
                    <li>🏆 Prizes for best costume and detective work</li>
                    <li>🍛 Delicious period-appropriate dinner</li>
                </ul>
            </div>

            <div class="how-to-play">
                <h4>📜 How to Play</h4>
                <p class="how-to-intro">
                    The game master will unlock each round as the evening progresses. Use your <strong>🎭 My Character</strong> page 
                    to follow along. Stay in character, mingle with the other guests, and follow the instructions for each round.
                    New instructions will appear automatically as each round is unlocked. 
                    Write everything down in your <strong>🗒️ Notebook</strong> to help you remember what you learn.
                </p>

                <div class="round-guide">
                    <div class="round-guide-item">
                        <h5>🎭 Round <strong>1</strong> — Introductions</h5>
                        <p>
                            Introduce yourself, as your character, to the other guests. Share your
                            background and goals openly — but keep your <em>secrets</em> close to the vest. Your Round 1
                            instructions will tell you exactly who to approach and what to say. Feel free to improvise, but remember: 
                            <em>not everything you say has to be true.</em>
                        </p>
                    </div>

                    <div class="round-guide-item">
                        <h5>🕵️ Round <bold>2</bold> — Investigation</h5>
                        <p>
                            <strong>Part A (Pre-Murder):</strong> Follow your new instructions to interact with specific characters,
                            reveal certain clues, and dig deeper into everyone's stories. Alibis are forming. Motives are surfacing.
                            Listen more than you speak.
                        </p>
                        <p>
                            <strong>Part B (Post-Murder):</strong> Someone's dead. The <strong>🔬 Forensic Report</strong>
                            becomes available with evidence — cause of death, ballistics, blood evidence, and more.
                            Click the buttons in the app to see the <strong>🔬 Forensic Report</strong> and the <strong>🗺️ Floor Plan</strong>.
                        </p>
                    </div>

                    <div class="round-guide-item">
                        <h5>⚡ Round <em>3</em> — The Reveal</h5>
                        <p>
                            Each character reveals their true motive in a specific order, watch for whom you follow. 
                            After all motives are revealed, then you'll find out <em>who committed the murder, and why?</em>
                        </p>
                        <p class="round-tip">
                            💡 <strong>Tip:</strong> The game is not over after the reveal. Stay alert — things may get
                            a little... <em>chaotic</em>. 🎇
                        </p>
                    </div>
                </div>

                <div class="golden-rules">
                    <h5>🥂 The Golden Rules</h5>
                    <ul>
                        <li><strong>Stay in character.</strong> First names, accents, mannerisms — commit to the bit.</li>
                        <li><strong>Lie, deflect, and scheme</strong> — but only about what your character would know.</li>
                        <li><strong>Never reveal your secret</strong> unless you're trading for something better.</li>
                        <li><strong>Trust no one.</strong> Especially the charming ones.</li>
                    </ul>
                </div>
            </div>

            <div class="navigation-section">
                <a href="characters" class="view-all-btn">👥 View All Characters</a>
                <a href="floorplan" class="floor-plan-btn">🗺️ Floor Plan</a>
                <a href="notebook" class="notebook-btn">🗒️ Notebook</a>
                @if (AdminAuthService.IsAuthenticated)
                {
                    <a href="admin" class="admin-btn">🛠️ Game Admin</a>
                }
            </div>

        </div>
    </div>

    <footer class="speakeasy-footer">
        <div class="footer-links">
            <a href="about">About</a>
            <span class="footer-divider">|</span>
            <a href="admin">Admin</a>
        </div>
        <p class="footer-copy">Silver Serpent Speakeasy © 2026</p>
    </footer>
</div>

<style>
    .speakeasy-container {
        max-width: 800px;
        margin: 0 auto;
        padding: 20px;
        font-family: 'Times New Roman', 'Segoe UI Emoji', 'Apple Color Emoji', 'Noto Color Emoji', serif;
        background: linear-gradient(135deg, #1a1a1a 0%, #2c2c2c 100%);
        color: #f5f5dc;
        min-height: 100vh;
        width: 100%;
    }

    @@media (max-width: 768px) {
        .speakeasy-container {
            padding: 10px;
        }

        .gatsby-title {
            font-size: 1.8rem;
        }

        .event-subtitle {
            font-size: 1.3rem;
        }

        .art-deco-border {
            padding: 15px;
        }

        .navigation-section {
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        .navigation-section a, .navigation-section button {
            width: 100%;
        }
    }

    .invitation-header {
        text-align: center;
        margin-bottom: 30px;
        border-bottom: 3px solid #d4af37;
        padding-bottom: 20px;
    }

    .gatsby-title {
        font-size: 2.5rem;
        color: #d4af37;
        text-shadow: 2px 2px 4px rgba(0,0,0,0.5);
        margin: 0;
        font-weight: bold;
    }

    .event-subtitle {
        font-size: 1.8rem;
        color: #f5f5dc;
        margin: 10px 0;
        font-style: italic;
    }

    .date-location {
        font-size: 1.2rem;
        color: #d4af37;
        margin: 10px 0;
    }

    .art-deco-border {
        border: 2px solid #d4af37;
        border-radius: 10px;
        padding: 30px;
        background: rgba(212, 175, 55, 0.05);
        box-shadow: inset 0 0 20px rgba(212, 175, 55, 0.1);
    }

    .invitation-text {
        font-size: 1.3rem;
        text-align: center;
        color: #d4af37;
        margin-bottom: 25px;
    }

    .invitation-details {
        font-size: 1.1rem;
        line-height: 1.6;
        margin-bottom: 25px;
        text-align: justify;
    }

    .party-details, .dress-code, .rsvp-info {
        margin: 25px 0;
        padding: 15px;
        border-left: 3px solid #d4af37;
        background: rgba(0,0,0,0.2);
    }

    .party-details h4, .dress-code h4 {
        color: #d4af37;
        margin-bottom: 15px;
    }

    .party-details ul {
        list-style: none;
        padding-left: 0;
    }

    .party-details ul li {
        margin: 8px 0;
        font-size: 1.1rem;
    }

    .how-to-play {
        margin: 25px 0;
        padding: 20px;
        border: 2px solid #8b4513;
        border-radius: 10px;
        background: rgba(139, 69, 19, 0.1);
    }

    .how-to-play h4 {
        color: #d4af37;
        margin-bottom: 10px;
        font-size: 1.2rem;
    }

    .how-to-intro {
        font-size: 1.05rem;
        line-height: 1.6;
        margin-bottom: 15px;
    }

    .round-guide-item {
        margin-bottom: 15px;
        padding: 12px;
        border-left: 3px solid #d4af37;
        background: rgba(0,0,0,0.2);
        border-radius: 0 6px 6px 0;
    }

    .round-guide-item:last-child {
        margin-bottom: 0;
    }

    .round-guide-item h5 {
        color: #d4af37;
        margin: 0 0 8px 0;
        font-size: 1.05rem;
    }

    .round-guide-item p {
        margin: 0 0 8px 0;
        line-height: 1.5;
        font-size: 0.95rem;
    }

    .round-guide-item p:last-child {
        margin-bottom: 0;
    }

    .navigation-section {
        text-align: center;
        margin: 30px 0;
    }

    .round-tip {
        font-size: 0.9rem;
        font-style: italic;
        color: #f39c12;
        margin-top: 5px;
    }

    .golden-rules {
        margin-top: 20px;
        padding: 10px;
        background: rgba(255, 215, 0, 0.1);
        border: 1px solid #ffd700;
        border-radius: 5px;
    }

    .golden-rules h5 {
        color: #d4af37;
        margin-bottom: 8px;
        font-size: 1.1rem;
    }

    .golden-rules ul {
        list-style: disc;
        padding-left: 20px;
        font-size: 0.95rem;
    }

    .golden-rules ul li {
        margin-bottom: 5px;
    }

    .speakeasy-footer {
        margin-top: 30px;
        padding: 20px;
        text-align: center;
        border-top: 1px solid #d4af37;
        background: rgba(0, 0, 0, 0.7);
        border-radius: 0 0 10px 10px;
    }

    .footer-links {
        margin-bottom: 10px;
    }

    .footer-links a {
        color: #d4af37;
        text-decoration: none;
        font-weight: bold;
        transition: color 0.2s ease;
    }

    .footer-links a:hover {
        color: #f5f5dc;
        text-decoration: underline;
    }

    .footer-divider {
        color: #8b4513;
        margin: 0 10px;
    }

    .footer-copy {
        font-size: 0.85rem;
        color: #999;
        margin: 0;
        font-style: italic;
    }
</style>
