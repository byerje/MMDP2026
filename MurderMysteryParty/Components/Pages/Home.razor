@page "/"
@using MurderMysteryParty.Services
@inject AdminAuthService AdminAuthService

<PageTitle>Murder Mystery Dinner Party - 1920's SpeakEasy Gala 2026</PageTitle>

<div class="speakeasy-container">
    <div class="invitation-header">
        <h1 class="gatsby-title">Murder Mystery Dinner Party</h1>
        <h2 class="event-subtitle">1920's SpeakEasy Gala 2026</h2>
        <h3 class="date-location">Mar 13, 2026 | Silver Serpent Speakeasy</h3>
    </div>

    <div class="invitation-content">
        <div class="art-deco-border">
            <p class="invitation-text">
                <em>Welcome to the past. Step back in time to the golden age of jazz, glitz, and glamour!</em>
            </p>
            
            <p class="invitation-details">
                Thank you for joining us for an evening of mystery, intrigue, and 1920s sophistication as we gather at Silver 
                Serpent Speakeasy for an unforgettable murder mystery dinner party. Don your finest flapper dress or sharpest suit, 
                and prepare to become part of a thrilling whodunit that will test your detective skills!
            </p>

            <div class="party-details">
                <h4>What Awaits You:</h4>
                <ul>
                    <li>🍸 Prohibition-era mocktails</li>
                    <li>🎭 Interactive murder mystery experience</li>
                    <li>🎷 Great music and 1920s entertainment</li>
                    <li>🏆 Prizes for best costume and detective work</li>
                    <li>🍛 Delicious period-appropriate dinner</li>
                </ul>
            </div>

            <div class="dress-code">
                <h4>Suggested Costumes: 1920s Speakeasy Chic</h4>
                <p>
                    <strong>Ladies:</strong> Flapper dresses, headbands with feathers, long pearl necklaces, T-bar shoes<br/>
                    <strong>Gentlemen:</strong> Three-piece suits, bow ties, suspenders, pocket watches, fedora hats
                </p>
            </div>

            <div class="navigation-section">
                <a href="characters" class="view-all-btn">👥 View All Characters</a>
                <a href="floorplan" class="floor-plan-btn">🗺️ Floor Plan</a>
                <a href="notebook" class="notebook-btn">🗒️ Notebook</a>
                @if (AdminAuthService.IsAuthenticated)
                {
                    <a href="admin" class="admin-btn">🛠️ Game Admin</a>
                }
            </div>

        </div>
    </div>
</div>

<style>
    .speakeasy-container {
        max-width: 800px;
        margin: 0 auto;
        padding: 20px;
        font-family: 'Times New Roman', serif;
        background: linear-gradient(135deg, #1a1a1a 0%, #2c2c2c 100%);
        color: #f5f5dc;
        min-height: 100vh;
    }

    .invitation-header {
        text-align: center;
        margin-bottom: 30px;
        border-bottom: 3px solid #d4af37;
        padding-bottom: 20px;
    }

    .gatsby-title {
        font-size: 2.5rem;
        color: #d4af37;
        text-shadow: 2px 2px 4px rgba(0,0,0,0.5);
        margin: 0;
        font-weight: bold;
    }

    .event-subtitle {
        font-size: 1.8rem;
        color: #f5f5dc;
        margin: 10px 0;
        font-style: italic;
    }

    .date-location {
        font-size: 1.2rem;
        color: #d4af37;
        margin: 10px 0;
    }

    .art-deco-border {
        border: 2px solid #d4af37;
        border-radius: 10px;
        padding: 30px;
        background: rgba(212, 175, 55, 0.05);
        box-shadow: inset 0 0 20px rgba(212, 175, 55, 0.1);
    }

    .invitation-text {
        font-size: 1.3rem;
        text-align: center;
        color: #d4af37;
        margin-bottom: 25px;
    }

    .invitation-details {
        font-size: 1.1rem;
        line-height: 1.6;
        margin-bottom: 25px;
        text-align: justify;
    }

    .party-details, .dress-code, .rsvp-info {
        margin: 25px 0;
        padding: 15px;
        border-left: 3px solid #d4af37;
        background: rgba(0,0,0,0.2);
    }

    .party-details h4, .dress-code h4 {
        color: #d4af37;
        margin-bottom: 15px;
    }

    .party-details ul {
        list-style: none;
        padding-left: 0;
    }

    .party-details ul li {
        margin: 8px 0;
        font-size: 1.1rem;
    }

    .navigation-section {
        text-align: center;
        margin: 30px 0;
    }
</style>
