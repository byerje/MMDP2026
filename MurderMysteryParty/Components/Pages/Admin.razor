@page "/admin"
@using MurderMysteryParty.Models
@using MurderMysteryParty.Services
@inject GameSessionService GameSessionService
@inject CharacterService CharacterService
@inject RoundSignalRService RoundSignalRService
@inject AdminAuthService AdminAuthService
@implements IDisposable

<PageTitle>Admin - Murder Mystery Game Control</PageTitle>

@if (!AdminAuthService.IsAuthenticated)
{
    <div class="admin-container">
        <div class="admin-header">
            <h1 class="admin-title">Game Admin</h1>
            <h2 class="admin-subtitle">Admin Login Required</h2>
            <div class="admin-navigation">
                <a href="" class="back-home-btn">🏠 Back to Home</a>
            </div>
        </div>

        <div class="game-status">
            <h3>Enter Admin Password</h3>
        </div>

        <div class="game-actions">
            <input class="admin-password" type="password" @bind="adminPassword" placeholder="Admin password" />
            <button class="auth-btn" @onclick="AuthenticateAdmin">Login</button>
            @if (!string.IsNullOrWhiteSpace(loginError))
            {
                <p class="reset-note">@loginError</p>
            }
        </div>
    </div>
}
else
{
    <div class="admin-container">
        <div class="admin-header">
            <h1 class="admin-title">Game Admin</h1>
            <h2 class="admin-subtitle">Round Control Center</h2>
            <div class="admin-navigation">
                <a href="" class="back-home-btn">🏠 Back to Home</a>
                <a href="characters" class="characters-btn">👥 All Characters</a>
                <a href="qr-codes" class="qr-codes-btn">📱 QR Codes</a>
                <button class="auth-btn" @onclick="Logout">Log Out</button>
            </div>
        </div>

        <div class="game-status">
            <h3>Current Status: @GameSessionService.GetCurrentRoundName()</h3>
        </div>

        <div class="round-controls">
            <div class="round-control-grid">
                <div class="round-card @(gameSession.IsRound1Unlocked ? "unlocked" : "")">
                    <h4>Round 1</h4>
                    <p>Initial character introductions and setup</p>
                    <button class="control-btn" @onclick="UnlockRound1" disabled="@gameSession.IsRound1Unlocked">
                        @(gameSession.IsRound1Unlocked ? "✓ Unlocked" : "Unlock Round 1")
                    </button>
                </div>

                <div class="round-card @(gameSession.IsRound2AUnlocked ? "unlocked" : "")">
                    <h4>Round 2 - Part A</h4>
                    <p>Pre-murder investigation and clue gathering</p>
                    <button class="control-btn" @onclick="UnlockRound2A" disabled="@gameSession.IsRound2AUnlocked">
                        @(gameSession.IsRound2AUnlocked ? "✓ Unlocked" : "Unlock Round 2A")
                    </button>
                </div>

                <div class="round-card @(gameSession.IsRound2BUnlocked ? "unlocked" : "")">
                    <h4>Round 2 - Part B</h4>
                    <p>Post-murder response and immediate investigation</p>
                    <button class="control-btn" @onclick="UnlockRound2B" disabled="@gameSession.IsRound2BUnlocked">
                        @(gameSession.IsRound2BUnlocked ? "✓ Unlocked" : "Unlock Round 2B")
                    </button>
                </div>

                <div class="round-card @((gameSession.IsRound3AUnlocked && gameSession.IsRound3BUnlocked) ? "unlocked" : "")">
                    <h4>Round 3</h4>
                    <p>Final reveal, motive reveals, and chaotic ending</p>
                    <button class="control-btn" @onclick="UnlockRound3" disabled="@(gameSession.IsRound3AUnlocked && gameSession.IsRound3BUnlocked)">
                        @((gameSession.IsRound3AUnlocked && gameSession.IsRound3BUnlocked) ? "✓ Unlocked" : "Unlock Round 3")
                    </button>
                </div>
            </div>
        </div>

        <div class="game-actions">
            <button class="reset-btn" @onclick="ResetAllRounds">
                🔄 Reset All Rounds
            </button>
            <p class="reset-note">This will lock all rounds back to the beginning</p>
            
            <button class="clear-assignment-btn" @onclick="ResetCharacterAssignments">
                🗑️ Reset Character Assignments
            </button>
            <p class="reset-note">This will clear all character assignments (does not affect rounds)</p>
            
            <button class="refresh-btn" @onclick="BroadcastCurrentAssignments">
                📡 Broadcast Assignments
            </button>
            <p class="reset-note">Broadcast current assignments to all connected players (for late arrivals)</p>

            <button class="direct-assignment-btn" @onclick="ToggleDirectAssignment">
                @(gameSession.IsDirectAssignmentAllowed ? "🔒 Lock to QR Scan Only" : "🔓 Allow Direct Assignment")
            </button>
            <p class="reset-note">
                @(gameSession.IsDirectAssignmentAllowed
                    ? "Players can currently tap a character card to claim it — click to require QR scan again"
                    : "Players must scan a QR code to claim a character — click to allow tapping as fallback")
            </p>
        </div>

        <div class="character-status">
            <h3>Character Assignment Status</h3>
            <div class="character-grid">
                @foreach (var character in allCharacters)
                {
                    <div class="character-status-card @(character.IsAssigned ? "assigned" : "")">
                        <h4>@character.Name</h4>
                        <p>@character.Occupation</p>
                        <span class="status-badge">@(character.IsAssigned ? "ASSIGNED" : "AVAILABLE")</span>
                    </div>
                }
            </div>
        </div>
    </div>
}

<style>
    .admin-container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 20px;
        font-family: 'Times New Roman', 'Segoe UI Emoji', 'Apple Color Emoji', 'Noto Color Emoji', serif;
        background: linear-gradient(135deg, #1a1a1a 0%, #2c2c2c 100%);
        color: #f5f5dc;
        min-height: 100vh;
        width: 100%;
    }

    @@media (max-width: 768px) {
        .admin-container {
            padding: 10px;
        }

        .admin-title {
            font-size: 1.8rem;
        }

        .admin-navigation {
            flex-direction: column;
            gap: 8px;
        }

        .admin-navigation a, .admin-navigation button {
            width: 100%;
        }

        .round-control-grid {
            grid-template-columns: 1fr;
        }

        .character-grid {
            grid-template-columns: 1fr;
        }
    }

    .admin-header {
        text-align: center;
        margin-bottom: 30px;
        border-bottom: 3px solid #d4af37;
        padding-bottom: 20px;
    }

    .admin-title {
        font-size: 2.5rem;
        color: #d4af37;
        text-shadow: 2px 2px 4px rgba(0,0,0,0.5);
        margin: 0;
        font-weight: bold;
    }

    .admin-subtitle {
        font-size: 1.4rem;
        color: #f5f5dc;
        margin: 10px 0;
        font-style: italic;
    }

    .admin-navigation {
        display: flex;
        justify-content: center;
        gap: 15px;
        flex-wrap: wrap;
        margin-top: 15px;
    }

    /* Button styles moved to wwwroot/app.css for site-wide consistency */

    .game-status {
        text-align: center;
        margin: 30px 0;
        padding: 20px;
        background: rgba(212, 175, 55, 0.1);
        border: 2px solid #d4af37;
        border-radius: 10px;
    }

    .game-status h3 {
        color: #d4af37;
        font-size: 1.5rem;
        margin: 0;
    }

    .round-control-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(min(100%, 300px), 1fr));
        gap: 20px;
        margin: 30px 0;
    }

    .round-card {
        background: rgba(139, 69, 19, 0.1);
        border: 2px solid #8b4513;
        border-radius: 10px;
        padding: 20px;
        text-align: center;
        transition: all 0.3s ease;
    }

    .round-card.unlocked {
        border-color: #d4af37;
        background: rgba(212, 175, 55, 0.1);
    }

    .round-card h4 {
        color: #d4af37;
        margin: 0 0 10px 0;
        font-size: 1.3rem;
    }

    .round-card p {
        margin: 0 0 15px 0;
        color: #ccc;
    }

    .control-btn {
        /* control button visual moved to app.css; keep layout-specific properties here if needed */
        width: 100%;
    }

    .control-btn:hover:not(:disabled) {
        /* hover handled in app.css */
    }

    .control-btn:disabled {
        /* disabled visual handled in app.css */
    }

    .game-actions {
        text-align: center;
        margin: 40px 0;
        padding: 20px;
        border-top: 2px solid #d4af37;
        border-bottom: 2px solid #d4af37;
    }

    .game-actions button {
        margin: 10px;
        min-width: 250px;
    }

    .reset-note {
        color: #ccc;
        font-size: 0.9rem;
        margin-top: 10px;
    }

    .character-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(min(100%, 250px), 1fr));
        gap: 15px;
        margin: 20px 0;
    }

    .character-status-card {
        background: rgba(139, 69, 19, 0.1);
        border: 1px solid #8b4513;
        border-radius: 8px;
        padding: 15px;
        text-align: center;
    }

    .character-status-card.assigned {
        border-color: #d4af37;
        background: rgba(212, 175, 55, 0.1);
    }

    .character-status-card h4 {
        color: #d4af37;
        margin: 0 0 5px 0;
        font-size: 1.1rem;
    }

    .character-status-card p {
        color: #ccc;
        margin: 0 0 10px 0;
        font-size: 0.9rem;
    }

    .status-badge {
        background: #8b4513;
        color: #f5f5dc;
        padding: 3px 8px;
        border-radius: 4px;
        font-size: 0.8rem;
        font-weight: bold;
    }

    .character-status-card.assigned .status-badge {
        background: #d4af37;
        color: #1a1a1a;
    }

    .admin-password {
        padding: 10px 14px;
        border-radius: 6px;
        border: 1px solid #d4af37;
        background: rgba(0,0,0,0.4);
        color: #f5f5dc;
        margin-right: 10px;
        min-width: 240px;
    }
</style>

@code {
    private GameSession gameSession = new();
    private List<Character> allCharacters = new();
    private string adminPassword = string.Empty;
    private string? loginError;

    protected override async Task OnInitializedAsync()
    {
        await AdminAuthService.InitializeAsync();
        gameSession = GameSessionService.GetGameSession();
        allCharacters = CharacterService.GetAllCharacters();
        CharacterService.OnAssignmentsChanged += OnAssignmentsChanged;
        RoundSignalRService.AssignmentSyncRequested += OnAssignmentSyncRequested;
    }

    private async void OnAssignmentsChanged()
    {
        await InvokeAsync(StateHasChanged);
    }

    private async Task OnAssignmentSyncRequested()
    {
        if (AdminAuthService.IsAuthenticated)
        {
            await BroadcastCurrentAssignments();
        }
    }

    public void Dispose()
    {
        CharacterService.OnAssignmentsChanged -= OnAssignmentsChanged;
        RoundSignalRService.AssignmentSyncRequested -= OnAssignmentSyncRequested;
    }

    private async Task AuthenticateAdmin()
    {
        loginError = null;
        if (await AdminAuthService.LoginAsync(adminPassword))
        {
            adminPassword = string.Empty;
            StateHasChanged();
            return;
        }

        loginError = "Invalid password.";
    }

    private async Task Logout()
    {
        await AdminAuthService.LogoutAsync();
        adminPassword = string.Empty;
        loginError = null;
    }

    private async Task UnlockRound1()
    {
        GameSessionService.UnlockRound1();
        gameSession = GameSessionService.GetGameSession();
        await RoundSignalRService.SendRoundUnlockedAsync(1);
        StateHasChanged();
    }

    private async Task UnlockRound2A()
    {
        GameSessionService.UnlockRound2A();
        gameSession = GameSessionService.GetGameSession();
        await RoundSignalRService.SendRoundUnlockedAsync(2);
        StateHasChanged();
    }

    private async Task UnlockRound2B()
    {
        GameSessionService.UnlockRound2B();
        gameSession = GameSessionService.GetGameSession();
        await RoundSignalRService.SendRoundUnlockedAsync(3);
        StateHasChanged();
    }

    private void UnlockRound3A()
    {
        GameSessionService.UnlockRound3A();
        gameSession = GameSessionService.GetGameSession();
        StateHasChanged();
    }

    private void UnlockRound3B()
    {
        GameSessionService.UnlockRound3B();
        gameSession = GameSessionService.GetGameSession();
        StateHasChanged();
    }

    private async Task UnlockRound3()
    {
        GameSessionService.UnlockRound3();
        gameSession = GameSessionService.GetGameSession();
        await RoundSignalRService.SendRoundUnlockedAsync(4);
        StateHasChanged();
    }

    private async Task ResetAllRounds()
    {
        GameSessionService.ResetGame();
        gameSession = GameSessionService.GetGameSession();
        await RoundSignalRService.SendRoundsResetAsync();
        StateHasChanged();
    }

    private async Task ResetCharacterAssignments()
    {
        CharacterService.ResetCharacterAssignments();
        
        await RoundSignalRService.SendAllAssignmentsResetAsync();
        
        allCharacters = CharacterService.GetAllCharacters();
        StateHasChanged();
    }

    private async Task BroadcastCurrentAssignments()
    {
        // Send current assignment state for all assigned characters
        // This helps late arrivals get up-to-date information
        var assignedCharacters = CharacterService.GetAllCharacters().Where(c => c.IsAssigned);
        
        foreach (var character in assignedCharacters)
        {
            await RoundSignalRService.SendCharacterAssignmentChangedAsync(character.Id, true);
        }
        
        // Also broadcast available characters to ensure consistency
        var availableCharacters = CharacterService.GetAllCharacters().Where(c => !c.IsAssigned);
        
        foreach (var character in availableCharacters)
        {
            await RoundSignalRService.SendCharacterAssignmentChangedAsync(character.Id, false);
        }
    }

    private async Task ToggleDirectAssignment()
    {
        var newValue = !gameSession.IsDirectAssignmentAllowed;
        GameSessionService.SetDirectAssignmentAllowed(newValue);
        gameSession = GameSessionService.GetGameSession();
        await RoundSignalRService.SendDirectAssignmentAllowedAsync(newValue);
        StateHasChanged();
    }
}
