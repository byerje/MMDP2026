@page "/admin"
@using MurderMysteryParty.Models
@using MurderMysteryParty.Services
@inject GameSessionService GameSessionService
@inject CharacterService CharacterService

<PageTitle>Admin - Murder Mystery Game Control</PageTitle>

<div class="admin-container">
    <div class="admin-header">
        <h1 class="admin-title">Game Administration</h1>
        <h2 class="admin-subtitle">Round Control Center</h2>
        <div class="admin-navigation">
            <a href="" class="back-home-btn">🏠 Back to Home</a>
            <a href="floorplan" class="floor-plan-btn">🗺️ Floor Plan</a>
            <a href="characters" class="characters-btn">👥 All Characters</a>
        </div>
    </div>

    <div class="game-status">
        <h3>Current Status: @GameSessionService.GetCurrentRoundName()</h3>
    </div>

    <div class="round-controls">
        <div class="round-control-grid">
            <div class="round-card @(gameSession.IsRound1Unlocked ? "unlocked" : "")">
                <h4>Round 1</h4>
                <p>Initial character introductions and setup</p>
                <button class="control-btn" @onclick="UnlockRound1" disabled="@gameSession.IsRound1Unlocked">
                    @(gameSession.IsRound1Unlocked ? "✓ Unlocked" : "Unlock Round 1")
                </button>
            </div>

            <div class="round-card @(gameSession.IsRound2AUnlocked ? "unlocked" : "")">
                <h4>Round 2 - Part A</h4>
                <p>Pre-murder investigation and clue gathering</p>
                <button class="control-btn" @onclick="UnlockRound2A" disabled="@gameSession.IsRound2AUnlocked">
                    @(gameSession.IsRound2AUnlocked ? "✓ Unlocked" : "Unlock Round 2A")
                </button>
            </div>

            <div class="round-card @(gameSession.IsRound2BUnlocked ? "unlocked" : "")">
                <h4>Round 2 - Part B</h4>
                <p>Post-murder response and immediate investigation</p>
                <button class="control-btn" @onclick="UnlockRound2B" disabled="@gameSession.IsRound2BUnlocked">
                    @(gameSession.IsRound2BUnlocked ? "✓ Unlocked" : "Unlock Round 2B")
                </button>
            </div>

            <div class="round-card @((gameSession.IsRound3AUnlocked && gameSession.IsRound3BUnlocked) ? "unlocked" : "")">
                <h4>Round 3</h4>
                <p>Final reveal, motive reveals, and chaotic ending</p>
                <button class="control-btn" @onclick="UnlockRound3" disabled="@(gameSession.IsRound3AUnlocked && gameSession.IsRound3BUnlocked)">
                    @((gameSession.IsRound3AUnlocked && gameSession.IsRound3BUnlocked) ? "✓ Unlocked" : "Unlock Round 3")
                </button>
            </div>
        </div>
    </div>

    <div class="game-actions">
        <button class="reset-btn" @onclick="ResetGame">
            🔄 Reset Entire Game
        </button>
        <p class="reset-note">This will reset all rounds and character assignments</p>
    </div>

    <div class="character-status">
        <h3>Character Assignment Status</h3>
        <div class="character-grid">
            @foreach (var character in allCharacters)
            {
                <div class="character-status-card @(character.IsAssigned ? "assigned" : "")">
                    <h4>@character.Name</h4>
                    <p>@character.Occupation</p>
                    <span class="status-badge">@(character.IsAssigned ? "ASSIGNED" : "AVAILABLE")</span>
                </div>
            }
        </div>
    </div>
</div>

<style>
    .admin-container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 20px;
        font-family: 'Times New Roman', serif;
        background: linear-gradient(135deg, #1a1a1a 0%, #2c2c2c 100%);
        color: #f5f5dc;
        min-height: 100vh;
    }

    .admin-header {
        text-align: center;
        margin-bottom: 30px;
        border-bottom: 3px solid #d4af37;
        padding-bottom: 20px;
    }

    .admin-title {
        font-size: 2.5rem;
        color: #d4af37;
        text-shadow: 2px 2px 4px rgba(0,0,0,0.5);
        margin: 0;
        font-weight: bold;
    }

    .admin-subtitle {
        font-size: 1.4rem;
        color: #f5f5dc;
        margin: 10px 0;
        font-style: italic;
    }

    .admin-navigation {
        display: flex;
        justify-content: center;
        gap: 15px;
        flex-wrap: wrap;
        margin-top: 15px;
    }

    /* Button styles moved to wwwroot/app.css for site-wide consistency */

    .game-status {
        text-align: center;
        margin: 30px 0;
        padding: 20px;
        background: rgba(212, 175, 55, 0.1);
        border: 2px solid #d4af37;
        border-radius: 10px;
    }

    .game-status h3 {
        color: #d4af37;
        font-size: 1.5rem;
        margin: 0;
    }

    .round-control-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 20px;
        margin: 30px 0;
    }

    .round-card {
        background: rgba(139, 69, 19, 0.1);
        border: 2px solid #8b4513;
        border-radius: 10px;
        padding: 20px;
        text-align: center;
        transition: all 0.3s ease;
    }

    .round-card.unlocked {
        border-color: #d4af37;
        background: rgba(212, 175, 55, 0.1);
    }

    .round-card h4 {
        color: #d4af37;
        margin: 0 0 10px 0;
        font-size: 1.3rem;
    }

    .round-card p {
        margin: 0 0 15px 0;
        color: #ccc;
    }

    .control-btn {
        /* control button visual moved to app.css; keep layout-specific properties here if needed */
        width: 100%;
    }

    .control-btn:hover:not(:disabled) {
        /* hover handled in app.css */
    }

    .control-btn:disabled {
        /* disabled visual handled in app.css */
    }

    .game-actions {
        text-align: center;
        margin: 40px 0;
        padding: 20px;
        border-top: 2px solid #d4af37;
    }

    .reset-note {
        color: #ccc;
        font-size: 0.9rem;
        margin-top: 10px;
    }

    .character-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 15px;
        margin: 20px 0;
    }

    .character-status-card {
        background: rgba(139, 69, 19, 0.1);
        border: 1px solid #8b4513;
        border-radius: 8px;
        padding: 15px;
        text-align: center;
    }

    .character-status-card.assigned {
        border-color: #d4af37;
        background: rgba(212, 175, 55, 0.1);
    }

    .character-status-card h4 {
        color: #d4af37;
        margin: 0 0 5px 0;
        font-size: 1.1rem;
    }

    .character-status-card p {
        color: #ccc;
        margin: 0 0 10px 0;
        font-size: 0.9rem;
    }

    .status-badge {
        background: #8b4513;
        color: #f5f5dc;
        padding: 3px 8px;
        border-radius: 4px;
        font-size: 0.8rem;
        font-weight: bold;
    }

    .character-status-card.assigned .status-badge {
        background: #d4af37;
        color: #1a1a1a;
    }
</style>

@code {
    private GameSession gameSession = new();
    private List<Character> allCharacters = new();

    protected override void OnInitialized()
    {
        gameSession = GameSessionService.GetGameSession();
        allCharacters = CharacterService.GetAllCharacters();
    }

    private void UnlockRound1()
    {
        GameSessionService.UnlockRound1();
        gameSession = GameSessionService.GetGameSession();
        StateHasChanged();
    }

    private void UnlockRound2A()
    {
        GameSessionService.UnlockRound2A();
        gameSession = GameSessionService.GetGameSession();
        StateHasChanged();
    }

    private void UnlockRound2B()
    {
        GameSessionService.UnlockRound2B();
        gameSession = GameSessionService.GetGameSession();
        StateHasChanged();
    }

    private void UnlockRound3A()
    {
        GameSessionService.UnlockRound3A();
        gameSession = GameSessionService.GetGameSession();
        StateHasChanged();
    }

    private void UnlockRound3B()
    {
        GameSessionService.UnlockRound3B();
        gameSession = GameSessionService.GetGameSession();
        StateHasChanged();
    }

    private void UnlockRound3()
    {
        GameSessionService.UnlockRound3();
        gameSession = GameSessionService.GetGameSession();
        StateHasChanged();
    }

    private void ResetGame()
    {
        GameSessionService.ResetGame();
        CharacterService.ResetCharacterAssignments();
        gameSession = GameSessionService.GetGameSession();
        allCharacters = CharacterService.GetAllCharacters();
        StateHasChanged();
    }
}