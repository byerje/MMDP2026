@page "/admin"
@using MurderMysteryParty.Models
@using MurderMysteryParty.Services

<PageTitle>Admin - Murder Mystery Game Control</PageTitle>

@if (!AdminAuthService.IsAuthenticated)
{
    <div class="admin-container">
        <div class="admin-header">
            <h1 class="admin-title">Game Admin</h1>
            <h2 class="admin-subtitle">Admin Login Required</h2>
            <div class="admin-navigation">
                <a href="" class="back-home-btn">🏠 Back to Home</a>
            </div>
        </div>

        <div class="game-status">
            <h3>Enter Admin Password</h3>
        </div>

        <div class="game-actions">
            <input class="admin-password" type="password" @bind="adminPassword" placeholder="Admin password" />
            <button class="auth-btn" @onclick="AuthenticateAdmin">Login</button>
            @if (!string.IsNullOrWhiteSpace(loginError))
            {
                <p class="reset-note">@loginError</p>
            }
        </div>
    </div>
}
else
{
    <div class="admin-container">
        <div class="admin-header">
            <h1 class="admin-title">Game Admin</h1>
            <h2 class="admin-subtitle">Round Control Center</h2>
            <div class="admin-navigation">
                <a href="" class="back-home-btn">🏠 Back to Home</a>
                <a href="characters" class="characters-btn">👥 All Characters</a>
                <a href="qr-codes" class="qr-codes-btn">📱 QR Codes</a>
                <button class="auth-btn" @onclick="Logout">Log Out</button>
            </div>
        </div>

        <div class="game-status">
            <h3>Current Status: @GameSessionService.GetCurrentRoundName()</h3>
        </div>

        <div class="round-controls">
            <div class="round-control-grid">
                <div class="round-card @(gameSession.IsRound1Unlocked ? "unlocked" : "")">
                    <h4>Round 1</h4>
                    <p>Initial character introductions and setup</p>
                    <button class="control-btn" @onclick="UnlockRound1" disabled="@gameSession.IsRound1Unlocked">
                        @(gameSession.IsRound1Unlocked ? "✓ Unlocked" : "Unlock Round 1")
                    </button>
                </div>

                <div class="round-card @(gameSession.IsRound2AUnlocked ? "unlocked" : "")">
                    <h4>Round 2 - Part A</h4>
                    <p>Pre-murder investigation and clue gathering</p>
                    <button class="control-btn" @onclick="UnlockRound2A" disabled="@gameSession.IsRound2AUnlocked">
                        @(gameSession.IsRound2AUnlocked ? "✓ Unlocked" : "Unlock Round 2A")
                    </button>
                </div>

                <div class="round-card @(gameSession.IsRound2BUnlocked ? "unlocked" : "")">
                    <h4>Round 2 - Part B</h4>
                    <p>Post-murder response and immediate investigation</p>
                    <button class="control-btn" @onclick="UnlockRound2B" disabled="@gameSession.IsRound2BUnlocked">
                        @(gameSession.IsRound2BUnlocked ? "✓ Unlocked" : "Unlock Round 2B")
                    </button>
                </div>

                <div class="round-card @((gameSession.IsRound3AUnlocked && gameSession.IsRound3BUnlocked) ? "unlocked" : "")">
                    <h4>Round 3</h4>
                    <p>Final reveal, motive reveals, and chaotic ending</p>
                    <button class="control-btn" @onclick="UnlockRound3" disabled="@(gameSession.IsRound3AUnlocked && gameSession.IsRound3BUnlocked)">
                        @((gameSession.IsRound3AUnlocked && gameSession.IsRound3BUnlocked) ? "✓ Unlocked" : "Unlock Round 3")
                    </button>
                </div>
            </div>
        </div>

        <div class="game-actions">
            <button class="reset-btn" @onclick="ResetAllRounds">
                🔄 Reset All Rounds
            </button>
            <p class="reset-note">This will lock all rounds back to the beginning</p>
            
            <button class="clear-assignment-btn" @onclick="ResetCharacterAssignments">
                🗑️ Reset Character Assignments
            </button>
            <p class="reset-note">This will clear all character assignments (does not affect rounds)</p>
            
            <button class="refresh-btn" @onclick="BroadcastCurrentAssignments">
                📡 Broadcast Assignments
            </button>
            <p class="reset-note">Broadcast current assignments to all connected players (for late arrivals)</p>

            <button class="direct-assignment-btn" @onclick="ToggleDirectAssignment">
                @(gameSession.IsDirectAssignmentAllowed ? "🔒 Lock to QR Scan Only" : "🔓 Allow Direct Assignment")
            </button>
            <p class="reset-note">
                @(gameSession.IsDirectAssignmentAllowed
                    ? "Players can currently tap a character card to claim it — click to require QR scan again"
                    : "Players must scan a QR code to claim a character — click to allow tapping as fallback")
            </p>
        </div>

        <div class="character-status">
            <h3>Character Assignment Status</h3>
            <div class="character-grid">
                @foreach (var character in allCharacters)
                {
                    <div class="character-status-card @(character.IsAssigned ? "assigned" : "")">
                        <h4>@character.Name</h4>
                        <p>@character.Occupation</p>
                        <span class="status-badge">@(character.IsAssigned ? "ASSIGNED" : "AVAILABLE")</span>
                    </div>
                }
            </div>
        </div>
    </div>
}
