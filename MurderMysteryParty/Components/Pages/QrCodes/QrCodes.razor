@page "/qr-codes"
@using MurderMysteryParty.Models
@using MurderMysteryParty.Services
@inject CharacterService CharacterService
@inject NavigationManager NavigationManager
@inject AdminAuthService AdminAuthService
@inject IJSRuntime JSRuntime

<PageTitle>QR Codes - Murder Mystery Party</PageTitle>

@if (!AdminAuthService.IsAuthenticated)
{
    <div class="qr-page-container">
        <div class="access-denied">
            <h1 class="page-title">🚫 Access Denied</h1>
            <p>This page is only available to the game administrator.</p>
            <a href="admin" class="back-home-btn">🔑 Go to Admin Login</a>
        </div>
    </div>
}
else
{
    <div class="qr-page-container">
        <div class="screen-only">
            <h1 class="page-title">QR Codes for Name Tags</h1>
            <p class="page-instructions">Print this page and cut out each QR code to attach to the back of each player's name tag.</p>
            <p class="page-instructions click-hint">Click any QR code to view it individually.</p>
            <div class="navigation-buttons">
                <a href="admin" class="admin-btn">🔧 Back to Admin</a>
                <a href="" class="back-home-btn">🏠 Back to Home</a>
                <button class="qr-codes-btn" @onclick="PrintPage">🖨️ Print</button>
            </div>
        </div>

        @if (selectedCharacter != null)
        {
            <div class="qr-overlay" @onclick="CloseOverlay">
                <div class="qr-overlay-content" @onclick:stopPropagation>
                    <button class="qr-overlay-close" @onclick="CloseOverlay">✕</button>
                    <div class="qr-overlay-image">
                        <img src="@BuildQrCodeUrl(selectedCharacter.Id, 300)" alt="QR code for @selectedCharacter.Name" />
                    </div>
                    <div class="qr-overlay-label">@selectedCharacter.Name</div>
                </div>
            </div>
        }

        <div class="qr-grid">
            @foreach (var character in allCharacters)
            {
                <div class="qr-card" @onclick="() => SelectCharacter(character)" role="button" tabindex="0">
                    <div class="qr-image">
                        <img src="@BuildQrCodeUrl(character.Id)" alt="QR code for @character.Name" />
                    </div>
                    <div class="qr-label">@character.Name</div>
                </div>
            }
        </div>
    </div>
}

@code {
    private List<Character> allCharacters = new();
    private Character? selectedCharacter;

    protected override async Task OnInitializedAsync()
    {
        await AdminAuthService.InitializeAsync();
        allCharacters = CharacterService.GetAllCharacters()
            .OrderBy(c => c.Name)
            .ToList();
    }

    private string BuildQrCodeUrl(int characterId, int size = 150)
    {
        var characterUrl = $"{NavigationManager.BaseUri}character/{characterId}?assign=true";
        return $"https://api.qrserver.com/v1/create-qr-code/?size={size}x{size}&data={Uri.EscapeDataString(characterUrl)}";
    }

    private void SelectCharacter(Character character)
    {
        selectedCharacter = character;
    }

    private void CloseOverlay()
    {
        selectedCharacter = null;
    }

    private async Task PrintPage()
    {
        await JSRuntime.InvokeVoidAsync("window.print");
    }
}
