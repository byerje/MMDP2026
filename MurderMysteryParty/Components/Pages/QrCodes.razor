@page "/qr-codes"
@using MurderMysteryParty.Models
@using MurderMysteryParty.Services
@inject CharacterService CharacterService
@inject NavigationManager NavigationManager
@inject AdminAuthService AdminAuthService
@inject IJSRuntime JSRuntime

<PageTitle>QR Codes - Murder Mystery Party</PageTitle>

@if (!AdminAuthService.IsAuthenticated)
{
    <div class="qr-page-container">
        <div class="access-denied">
            <h1 class="page-title">🚫 Access Denied</h1>
            <p>This page is only available to the game administrator.</p>
            <a href="admin" class="back-home-btn">🔑 Go to Admin Login</a>
        </div>
    </div>
}
else
{
    <div class="qr-page-container">
        <div class="screen-only">
            <h1 class="page-title">QR Codes for Name Tags</h1>
            <p class="page-instructions">Print this page and cut out each QR code to attach to the back of each player's name tag.</p>
            <div class="navigation-buttons">
                <a href="admin" class="admin-btn">🔧 Back to Admin</a>
                <a href="" class="back-home-btn">🏠 Back to Home</a>
                <button class="qr-codes-btn" @onclick="PrintPage">🖨️ Print</button>
            </div>
        </div>

        <div class="qr-grid">
            @foreach (var character in allCharacters)
            {
                <div class="qr-card">
                    <div class="qr-image">
                        <img src="@BuildQrCodeUrl(character.Id)" alt="QR code for @character.Name" />
                    </div>
                    <div class="qr-label">@character.Name</div>
                </div>
            }
        </div>
    </div>
}

<style>
    .qr-page-container {
        max-width: 1000px;
        margin: 0 auto;
        padding: 20px;
        font-family: 'Times New Roman', serif;
        background: linear-gradient(135deg, #1a1a1a 0%, #2c2c2c 100%);
        color: #f5f5dc;
        min-height: 100vh;
    }

    .page-title {
        text-align: center;
        font-size: 2rem;
        color: #d4af37;
        margin: 0 0 10px 0;
    }

    .page-instructions {
        text-align: center;
        font-size: 1rem;
        color: #ccc;
        margin: 0 0 20px 0;
    }

    .navigation-buttons {
        display: flex;
        justify-content: center;
        gap: 15px;
        flex-wrap: wrap;
        margin-bottom: 25px;
    }

    .qr-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 20px;
        justify-items: center;
    }

    .qr-card {
        border: 2px dashed #888;
        border-radius: 8px;
        padding: 12px;
        text-align: center;
        background: rgba(255, 255, 255, 0.03);
        width: 200px;
    }

    .qr-image img {
        width: 150px;
        height: 150px;
        display: block;
        margin: 0 auto;
    }

    .qr-label {
        margin-top: 8px;
        font-size: 1rem;
        font-weight: bold;
        color: #d4af37;
    }

    .access-denied {
        text-align: center;
        padding: 60px 20px;
    }

    .access-denied p {
        font-size: 1.1rem;
        color: #ccc;
        margin: 20px 0;
    }

    @@media print {
        .screen-only {
            display: none;
        }

        .qr-page-container {
            background: #fff;
            color: #000;
            padding: 0;
            margin: 0;
            max-width: 100%;
        }

        .qr-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 10px;
            page-break-inside: auto;
        }

        .qr-card {
            border: 1px dashed #aaa;
            padding: 8px;
            background: #fff;
            page-break-inside: avoid;
            width: 180px;
        }

        .qr-image img {
            width: 140px;
            height: 140px;
        }

        .qr-label {
            color: #000;
            font-size: 0.9rem;
        }
    }
</style>

@code {
    private List<Character> allCharacters = new();

    protected override async Task OnInitializedAsync()
    {
        await AdminAuthService.InitializeAsync();
        allCharacters = CharacterService.GetAllCharacters()
            .OrderBy(c => c.Name)
            .ToList();
    }

    private string BuildQrCodeUrl(int characterId)
    {
        var characterUrl = $"{NavigationManager.BaseUri}character/{characterId}?assign=true";
        return $"https://api.qrserver.com/v1/create-qr-code/?size=150x150&data={Uri.EscapeDataString(characterUrl)}";
    }

    private async Task PrintPage()
    {
        await JSRuntime.InvokeVoidAsync("window.print");
    }
}
