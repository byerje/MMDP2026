@page "/my-character"
@using MurderMysteryParty.Models
@using MurderMysteryParty.Services

<PageTitle>My Character - Murder Mystery</PageTitle>

<div class="character-detail-container">
    @if (currentCharacter != null)
    {
        <div class="character-header">
            <h1 class="character-name">@currentCharacter.Name</h1>
            <h2 class="character-occupation">@currentCharacter.Occupation</h2>
            @if (isSyncing)
            {
                <p class="refresh-message syncing-message">⏳ Syncing with host...</p>
            }
            else if (showRefreshMessage)
            {
                <p class="refresh-message">✓ Character data refreshed!</p>
            }
            <div class="navigation-links">
                <a href="" class="nav-btn">🏠 Back to Home</a>
                <a href="characters" class="characters-btn">👥 All Characters</a>
                <a href="floorplan" class="nav-btn floor-plan-btn">🗺️ Floor Plan</a>
                <a href="notebook" class="notebook-btn">🗒️ Notebook</a>
                @if (GameSessionService.GetGameSession().IsRound2BUnlocked)
                {
                    <a href="forensic-report" class="nav-btn forensic-btn">🔬 Forensic Report</a>
                }
                else
                {
                    <button class="nav-btn forensic-btn-locked" disabled title="Available after Round 2B is unlocked">🔒 Forensic Report</button>
                }
                <button class="refresh-btn" @onclick="RefreshGameState">🔄 Refresh</button>
                <button class="clear-btn" @onclick="ClearAssignment">Clear My Assignment</button>
            </div>
        </div>

        <div class="character-profile">
            <div class="profile-section">
                <h3>Your Character Profile</h3>
                <div class="profile-grid">
                    <div class="profile-item">
                        <h4>Background</h4>
                        <p>@currentCharacter.Background</p>
                    </div>
                    <div class="profile-item">
                        <h4>Personality</h4>
                        <p>@currentCharacter.PersonalityTraits</p>
                    </div>
                    <div class="profile-item">
                        <h4>Goals</h4>
                        <p>@currentCharacter.Goals</p>
                    </div>
                    <div class="profile-item">
                        <h4>Costume</h4>
                        <p>@currentCharacter.Costume</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="rounds-container">
            <div class="current-round-status">
                <h3>Game Status: @GameSessionService.GetCurrentRoundName()</h3>
            </div>

            <div class="rounds-grid">
                @if (gameSession.IsRound1Unlocked)
                {
                    <div class="round-card unlocked">
                        <h4>🎭 Round 1</h4>
                        <div class="round-content">
                            @if (!string.IsNullOrEmpty(currentCharacter.Round1Content))
                            {
                                @((MarkupString)FormatRoundContent(currentCharacter.Round1Content))
                            }
                            else
                            {
                                <p><em>Round 1 content coming soon...</em></p>
                            }
                        </div>
                    </div>
                }
                else
                {
                    <div class="round-card locked">
                        <h4>🔒 Round 1</h4>
                        <p class="locked-text">Waiting for game master to unlock...</p>
                    </div>
                }

                @if (gameSession.IsRound2AUnlocked)
                {
                    <div class="round-card unlocked">
                        <h4>🕵️ Round 2 - Part A</h4>
                        <p class="round-subtitle">Pre-Murder Investigation</p>
                        <div class="round-content">
                            @if (!string.IsNullOrEmpty(currentCharacter.Round2AContent))
                            {
                                @((MarkupString)FormatRound2Content(currentCharacter.Round2AContent))
                            }
                            else
                            {
                                <p><em>Round 2A content coming soon...</em></p>
                            }
                        </div>
                    </div>
                }
                else
                {
                    <div class="round-card locked">
                        <h4>🔒 Round 2 - Part A</h4>
                        <p class="locked-text">Waiting for game master to unlock...</p>
                    </div>
                }

                @if (gameSession.IsRound2BUnlocked)
                {
                    <div class="round-card unlocked danger">
                        <h4>💀 Round 2 - Part B</h4>
                        <p class="round-subtitle">Post-Murder Response</p>
                        <div class="round-content">
                            @if (!string.IsNullOrEmpty(currentCharacter.Round2BContent))
                            {
                                @((MarkupString)FormatRound2Content(currentCharacter.Round2BContent))
                            }
                            else
                            {
                                <p><em>Round 2B content coming soon...</em></p>
                            }
                        </div>
                    </div>
                }
                else
                {
                    <div class="round-card locked">
                        <h4>🔒 Round 2 - Part B</h4>
                        <p class="locked-text">Waiting for game master to unlock...</p>
                    </div>
                }

                @if (gameSession.IsRound3AUnlocked)
                {
                    <div class="round-card unlocked warning">
                        <h4>🎯 Round 3 - Part A</h4>
                        <p class="round-subtitle">Motive Reveal</p>
                        <div class="round-content">
                            @if (!string.IsNullOrEmpty(currentCharacter.Round3AMotiveReveal))
                            {
                                @((MarkupString)FormatRound3AContent(currentCharacter.Round3AMotiveReveal))
                            }
                            else
                            {
                                <p><em>Motive reveal coming soon...</em></p>
                            }
                        </div>
                    </div>
                }
                else
                {
                    <div class="round-card locked">
                        <h4>🔒 Round 3 - Part A</h4>
                        <p class="locked-text">Waiting for game master to unlock...</p>
                    </div>
                }

                @if (gameSession.IsRound3BUnlocked)
                {
                    <div class="round-card unlocked chaos">
                        <h4>⚡ Round 3 - Part B</h4>
                        <p class="round-subtitle">Chaotic Ending</p>
                        <div class="round-content">
                            @if (!string.IsNullOrEmpty(currentCharacter.Round3BChaoticEnding))
                            {
                                @((MarkupString)FormatRound3BContent(currentCharacter.Round3BChaoticEnding))
                            }
                            else
                            {
                                <p><em>Final round instructions coming soon...</em></p>
                            }
                        </div>
                    </div>
                }
                else
                {
                    <div class="round-card locked">
                        <h4>🔒 Round 3 - Part B</h4>
                        <p class="locked-text">Waiting for game master to unlock...</p>
                    </div>
                }
            </div>
        </div>

        <div class="character-secrets">
            <h3>🤫 Your Secret Information</h3>
            <div class="secrets-content">
                <p>@currentCharacter.Secrets</p>
                <p class="secrets-warning"><strong>⚠️ Keep this information private! Unless you wish to reveal it in order to gain others' secrets'.</strong></p>
            </div>
        </div>

        <div class="character-notes">
            <h3>🗒️ Your Notes</h3>
            <p style="text-align: center; margin-bottom: 15px;">
                <a href="notebook" class="notebook-btn">📝 Open Full Notebook</a>
            </p>
            <textarea class="notes-input" @bind="notesText" @bind:after="SaveNotesAsync" placeholder="Quick notes (or use the full notebook)..."></textarea>
        </div>
    }
    else
    {
        <div class="no-character">
            <h2>No Character Assigned</h2>
            <p>You haven't been assigned a character yet. Please go back to the home page and get your character assignment.</p>
            <a href="" class="nav-btn">← Back to Home</a>
        </div>
    }
</div>



