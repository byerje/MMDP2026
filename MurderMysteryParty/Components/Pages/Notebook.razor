@page "/notebook"
@inject IJSRuntime JSRuntime

<PageTitle>Notebook - Murder Mystery Party</PageTitle>

<div class="notebook-container">
    <div class="notebook-header">
        <h1 class="notebook-title">🗒️ Detective Notebook</h1>
        <h2 class="notebook-subtitle">Your Personal Investigation Notes</h2>
        <div class="notebook-navigation">
            <a href="" class="back-home-btn">🏠 Back to Home</a>
            <a href="my-character" class="character-btn">🎭 My Character</a>
            <a href="characters" class="characters-btn">👥 All Characters</a>
        </div>
    </div>

    <div class="notebook-body">
        <div class="notebook-instructions">
            <p>Use this space to keep track of clues, suspects, alibis, and your theories about the murder mystery.</p>
        </div>

        <div class="notebook-editor">
            <textarea class="notes-input" @bind="notesText" @bind:after="SaveNotesAsync" placeholder="Write your investigation notes here..."></textarea>
        </div>
    </div>
</div>

<style>
    .notebook-container {
        max-width: 1000px;
        margin: 0 auto;
        padding: 20px;
        font-family: 'Times New Roman', 'Segoe UI Emoji', 'Apple Color Emoji', 'Noto Color Emoji', serif;
        background: linear-gradient(135deg, #1a1a1a 0%, #2c2c2c 100%);
        color: #f5f5dc;
        min-height: 100vh;
        width: 100%;
    }

    @@media (max-width: 768px) {
        .notebook-container {
            padding: 10px;
        }

        .notebook-title {
            font-size: 1.8rem;
        }

        .notebook-body {
            padding: 15px;
        }

        .notebook-navigation {
            flex-direction: column;
            gap: 8px;
        }

        .notebook-navigation a {
            width: 100%;
        }

        .notes-input {
            font-size: 0.95rem;
            min-height: 300px;
        }
    }

    .notebook-header {
        text-align: center;
        margin-bottom: 30px;
        border-bottom: 3px solid #d4af37;
        padding-bottom: 20px;
    }

    .notebook-title {
        font-size: 2.5rem;
        color: #d4af37;
        text-shadow: 2px 2px 4px rgba(0,0,0,0.5);
        margin: 0;
        font-weight: bold;
    }

    .notebook-subtitle {
        font-size: 1.2rem;
        color: #f5f5dc;
        margin: 10px 0;
        font-style: italic;
    }

    .notebook-navigation {
        margin-top: 15px;
        display: flex;
        justify-content: center;
        gap: 12px;
        flex-wrap: wrap;
    }

    .notebook-body {
        background: rgba(212, 175, 55, 0.05);
        border: 2px solid #d4af37;
        border-radius: 10px;
        padding: 30px;
    }

    .notebook-instructions {
        text-align: center;
        margin-bottom: 20px;
        padding-bottom: 20px;
        border-bottom: 1px solid #8b4513;
    }

    .notebook-instructions p {
        margin: 8px 0;
        color: #ccc;
    }

    .auto-save-note {
        font-size: 0.9rem;
        color: #d4af37;
        font-style: italic;
    }

    .notebook-editor {
        margin-top: 20px;
    }

    .notes-input {
        width: 100%;
        min-height: 400px;
        background: rgba(0, 0, 0, 0.5);
        border: 2px solid #d4af37;
        color: #f5f5dc;
        border-radius: 8px;
        padding: 15px;
        font-family: 'Times New Roman', serif;
        font-size: 1.05rem;
        line-height: 1.6;
        resize: vertical;
    }

    .notes-input::placeholder {
        color: #999;
        font-style: italic;
    }

    .notes-input:focus {
        outline: none;
        border-color: #d4af37;
        box-shadow: 0 0 10px rgba(212, 175, 55, 0.3);
    }
</style>

@code {
    private string notesText = string.Empty;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadNotesAsync();
            StateHasChanged();
        }
    }

    private async Task LoadNotesAsync()
    {
        try
        {
            notesText = await JSRuntime.InvokeAsync<string>("localStorage.getItem", "playerNotes") ?? string.Empty;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading notes: {ex.Message}");
        }
    }

    private void OnNotesChanged(ChangeEventArgs e)
    {
        notesText = e.Value?.ToString() ?? string.Empty;
    }

    private async Task SaveNotesAsync()
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("localStorage.setItem", "playerNotes", notesText ?? string.Empty);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error saving notes: {ex.Message}");
        }
    }
}
